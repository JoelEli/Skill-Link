# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/skilllink?retryWrites=true&w=majority

# JWT Secret Key — use a long random string (32+ characters)
JWT_SECRET=your_super_secret_jwt_key_at_least_32_chars_long

# Server Port
PORT=5000

# Environment (development | production)
NODE_ENV=development

# Allowed CORS origins (comma-separated, used in production)
# Example: https://skill-link-drab.vercel.app,https://your-other-domain.com
CORS_ORIGIN=http://localhost:5000
